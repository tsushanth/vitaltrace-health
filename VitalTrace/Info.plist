<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSCameraUsageDescription</key>
	<string>VitalTrace uses your camera to measure heart rate and blood oxygen (SpO2) by analyzing blood flow through your fingertip using photoplethysmography.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>VitalTrace reads your health data from Apple Health to provide comprehensive health insights and trend analysis.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>VitalTrace saves your heart rate, blood oxygen, and HRV readings to Apple Health for comprehensive health tracking.</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>This identifier will be used to deliver personalized health insights and measure app performance.</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
		<key>UIImageName</key>
		<string>LaunchIcon</string>
	</dict>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.appfactory.vitaltrace.healthsync</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleDisplayName</key>
	<string>VitalTrace</string>
	<key>CFBundleIdentifier</key>
	<string>com.appfactory.vitaltrace</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
